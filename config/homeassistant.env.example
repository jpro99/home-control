# Home Assistant connection settings for the BFF.
# Copy to homeassistant.env and fill in after provisioning HA.
#
#   cp config/homeassistant.env.example config/homeassistant.env

# Base URL of the Home Assistant instance (no trailing slash)
HA_URL=http://192.168.1.50:8123

# Long-lived access token (Profile → Long-Lived Access Tokens in HA UI)
HA_TOKEN=

# WebSocket URL (optional; script derives from HA_URL if unset)
# HA_WS_URL=ws://192.168.1.50:8123/api/websocket

# Request timeout in seconds (optional, default 10)
# HA_TIMEOUT=10
