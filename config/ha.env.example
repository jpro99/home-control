# Home Assistant connection settings for the BFF and verification scripts.
# Copy to config/ha.env (or export in your shell) and fill in real values.

# Base URL reachable from the BFF host (no trailing slash).
HA_URL=http://192.168.1.100:8123

# Long-lived access token (Profile → Security → Long-Lived Access Tokens).
HA_TOKEN=your_long_lived_access_token_here

# Optional: request timeout in seconds (default: 10).
# HA_TIMEOUT=10
